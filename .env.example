# Server Configuration
PORT=3001
NODE_ENV=development

# PawaPay Configuration
PAWAPAY_API_TOKEN=your_pawapay_bearer_token
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io
PAWAPAY_WEBHOOK_URL=https://your-domain.com/api/payments/webhook

# African's Talking Configuration
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key
AT_SENDER_ID=VIBELINX

# Database/Supabase Configuration (for booking verification)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Security
API_SECRET_KEY=your_secret_key_for_jwt_or_encryption
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
