# Server Configuration
PORT=3001
NODE_ENV=development

# Lenco Pay v2 Configuration
LENCOPAY_API_KEY=your_lenco_api_token
LENCOPAY_BASE_URL=https://api.lenco.co/access/v2
LENCOPAY_CALLBACK_URL=https://your-domain.com/api/payments/callback
LENCOPAY_ACCOUNT_ID=8309a71a-e0ad-48ab-b304-e2263d789386  # Required for transfers (36-char UUID)

# African's Talking Configuration
AT_USERNAME=your_africastalking_username
AT_API_KEY=your_africastalking_api_key
AT_SENDER_ID=VIBELINX

# Database/Supabase Configuration (for booking verification)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Security
API_SECRET_KEY=your_secret_key_for_jwt_or_encryption
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
